{
  "name": "nodebb-plugin-web-push",
  "version": "0.8.0",
  "description": "A plugin for adding native push notifications to NodeBB via the Web Push API.",
  "main": "library.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodebb/nodebb-plugin-web-push"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint ."
  },
  "keywords": [
    "nodebb",
    "plugin",
    "web-push",
    "shell"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ]
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nodebb/nodebb-plugin-web-push/issues"
  },
  "readmeFilename": "README.md",
  "nbbpm": {
    "compatibility": "^4.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-angular": "21.1.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-nodebb": "^2.0.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.8"
  },
  "dependencies": {
    "validator": "^13.12.0",
    "web-push": "^3.6.7"
  }
}
